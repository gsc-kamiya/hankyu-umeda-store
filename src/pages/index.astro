---
import Layout from '../layouts/Layout.astro';
---
<Layout title="TOP">
	<style>
		.hero {
			height: 80vh;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: flex-start;
			padding: 0 10%;
			background: linear-gradient(45deg, rgba(0,0,0,0.8), transparent), url('https://images.unsplash.com/photo-1519125323398-675f0ddb6308?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');
			background-size: cover;
			background-position: center;
		}
		.hero h1 {
			font-size: 5rem;
			line-height: 1;
			margin: 0;
			font-weight: 900;
			text-transform: uppercase;
			letter-spacing: -2px;
			transform: skewX(-5deg);
		}
		.hero h1 span {
			display: block;
			color: var(--primary);
		}
		.hero .sub {
			font-size: 1.5rem;
			font-weight: 700;
			margin-top: 20px;
			border-left: 10px solid var(--primary);
			padding-left: 20px;
		}
		.card {
			background: #222;
			border: 1px solid #333;
			transition: transform 0.3s;
			position: relative;
			overflow: hidden;
		}
		.card:hover {
			transform: translateY(-10px);
			border-color: var(--primary);
		}
		.card img {
			width: 100%;
			height: 200px;
			object-fit: cover;
			filter: grayscale(100%);
			transition: 0.3s;
		}
		.card:hover img {
			filter: grayscale(0%);
		}
		.card-content {
			padding: 20px;
		}
		.card-tag {
			background: var(--primary);
			color: white;
			padding: 2px 10px;
			font-size: 0.7rem;
			font-weight: 900;
			display: inline-block;
			margin-bottom: 10px;
		}
		.card h3 {
			margin: 0;
			font-size: 1.2rem;
			font-weight: 900;
		}
	</style>
	<main>
		<section class="hero">
			<h1>WELCOME TO<span>THE NEXT STAGE</span></h1>
			<p class="sub">阪急梅田本店 | 常識を、超えてゆけ。</p>
		</section>

		<h2 class="section-title">Latest News</h2>
		<div class="grid">
			<div class="card">
				<img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=800&q=80" alt="News 1" />
				<div class="card-content">
					<span class="card-tag">NEW ARRIVAL</span>
					<h3>2026 Spring Collection 公開</h3>
				</div>
			</div>
			<div class="card">
				<img src="https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?auto=format&fit=crop&w=800&q=80" alt="News 2" />
				<div class="card-content">
					<span class="card-tag">EVENT</span>
					<h3>9階 祝祭広場：ワールドフェア開催</h3>
				</div>
			</div>
			<div class="card">
				<img src="https://images.unsplash.com/photo-1567401893414-76b7b1e5a7a5?auto=format&fit=crop&w=800&q=80" alt="News 3" />
				<div class="card-content">
					<span class="card-tag">FOOD</span>
					<h3>地下1階：限定スイーツセレクション</h3>
				</div>
			</div>
		</div>
	</main>
</Layout>
